# ============================================================================
# CONFIGURACIÓN PARA PRUEBAS DE ESTRÉS - KAA IYA
# ============================================================================
# Copia este archivo a .env.stress-test y configura tus valores reales
# ============================================================================

# URLs del proyecto
VITE_BASE_URL=http://localhost:3000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Configuración de k6 para pruebas de carga
K6_BASE_URL=http://localhost:3000
K6_SUPABASE_URL=https://your-project.supabase.co
K6_SUPABASE_ANON_KEY=your-anon-key-here

# Opciones de prueba
K6_VUS=10
K6_DURATION=10m
K6_ITERATIONS=100

# Umbrales de rendimiento (en milisegundos)
K6_THRESHOLD_RESPONSE_TIME=1000
K6_THRESHOLD_DB_QUERY=500
K6_THRESHOLD_ERROR_RATE=5

# Configuración de monitoreo
VITE_ENABLE_PERFORMANCE_MONITOR=true
VITE_ENABLE_WEB_VITALS=true
VITE_SENTRY_DSN=

# Configuración de Supabase para almacenamiento de métricas
# (Las tablas se crean automáticamente con el script SQL)
SUPABASE_PERFORMANCE_TABLE=performance_metrics
SUPABASE_WEB_VITALS_TABLE=web_vitals
SUPABASE_SLOW_QUERIES_TABLE=slow_queries