# Variables que consume docker-compose.yml (stack completo en un solo servidor/VPS).
# Copia a .env y ajusta. Todo tiene un default que funciona "out of the box" para levantar
# el stack en localhost con su propio Postgres — solo hace falta tocar lo que corresponda
# a tu entorno real (dominio, credenciales, o si algún componente corre en otro lado).

# ── Postgres del contenedor local (usado si NO seteás DB_HOST más abajo) ──
POSTGRES_USER=amazonia
POSTGRES_PASSWORD=amazonia
POSTGRES_DB=amazonia

# ── Base de datos: por defecto usa el Postgres de este compose. ──
# Para conectar a una BD externa (Supabase, RDS, otro servidor), descomenta y completa
# estas 5 variables — el contenedor `api` se conecta ahí en vez de al Postgres local
# (que igual arranca, pero queda sin usar).
# DB_HOST=<host-externo>
# DB_PORT=5432
# DB_USER=<usuario>
# DB_PASSWORD=<password>
# DB_NAME=<nombre-bd>

# ── Backend ──
# Puerto interno del contenedor api (raro tocarlo; si lo cambiás, API_UPSTREAM de web
# se ajusta solo). No confundir con WEB_PORT (ese es el puerto expuesto al host).
# API_PORT=3333
JWT_SECRET=kaa-iya-docker-secret-change-me
JWT_TIME_EXPIRE=24h
SEED_SUPERADMIN_EMAIL=superadmin@kaaiya.test
SEED_SUPERADMIN_PASSWORD=SuperPass1!

# Dominio real del frontend (CORS). En producción, usar el dominio público, no localhost.
DOMAIN_FRONTEND=http://localhost
# URL pública donde el backend sirve /uploads (imágenes). Ajustar al dominio real.
UPLOADS_BASE_URL=http://localhost/uploads

# ── GeoRef: por defecto usa el servicio `georef` de este compose. ──
# Puerto interno del contenedor georef (si lo cambiás, GEOREF_URL de api se ajusta solo).
# GEOREF_PORT=8001
# Si georef corre en otro host/deploy, poner su URL completa (ej. https://georef.midominio.com).
# GEOREF_URL=http://georef:8001
# Orígenes permitidos por CORS de GeoRef (array JSON). Ajustar al dominio real del backend.
GEOREF_ALLOWED_ORIGINS=["http://localhost"]

# ── Frontend ──
# Clave de MapTiler para los mapas (opcional, pero recomendada en producción)
VITE_MAPTILER_KEY=
# URL de la API que se hornea en el build del frontend. "/api" = relativa (proxy de nginx,
# mismo origen). Si el frontend se despliega por separado del backend, usar la URL absoluta
# real del backend (ej. https://api.midominio.com/api).
# VITE_API_URL=/api
# Host:puerto del backend al que nginx hace proxy en runtime. Debe ser coherente con
# VITE_API_URL cuando este es relativo ("/api"). Si el backend corre en otro contenedor/host,
# poner acá su host:puerto (ej. api.midominio.com:3333).
# API_UPSTREAM=api:3333

# Puerto del host para el entrypoint web (por defecto 80 → http://localhost)
WEB_PORT=80
