# Variables que consume docker-compose.yml (stack local con Docker).
# Copia a .env y ajusta si quieres. Son credenciales LOCALES del contenedor
# Postgres — no son las de Supabase (esas viven en cada api-rest-amazonia/.env
# y no se usan dentro de los contenedores).

# Postgres local
POSTGRES_USER=amazonia
POSTGRES_PASSWORD=amazonia
POSTGRES_DB=amazonia

# Backend
JWT_SECRET=kaa-iya-docker-secret-change-me
SEED_SUPERADMIN_EMAIL=superadmin@kaaiya.test
SEED_SUPERADMIN_PASSWORD=SuperPass1!

# Frontend (opcional): clave de MapTiler para los mapas
VITE_MAPTILER_KEY=

# Puerto del host para el entrypoint web (por defecto 80 → http://localhost)
WEB_PORT=80
