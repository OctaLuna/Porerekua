#Backend
NODE_ENV=development
DOMAIN_FRONTEND=*
PORT=3333

# Database configuration
DB_TYPE=database
DB_HOST=localhost
DB_PORT=1234
DB_USER=database
DB_NAME=database
DB_PASSWORD=password
DB_LOGS=false

# JWT configuration
ACTIVE_JWT=true
JWT_SECRET=123456789
JWT_TIME_EXPIRE=1h

# Uploads (filesystem local)
UPLOADS_PATH=./uploads
UPLOADS_BASE_URL=http://localhost:3333/uploads

# GeoRef microservice (georef-service/)
GEOREF_URL=http://127.0.0.1:8001
GEOREF_TIMEOUT_MS=5000